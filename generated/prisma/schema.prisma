generator client {
  provider = "prisma-client-js"
  output   = "../../../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ── SISTEMA DE AUTENTICACIÓN INDEPENDIENTE ──

enum lms_rol_usuario {
  ADMINISTRADOR
  PROFESOR
  ESTUDIANTE
}

model usuarios {
  guid       String          @id @default(uuid())
  email      String          @unique
  contrasena String
  nombre     String
  apellido   String
  rol        lms_rol_usuario @default(ESTUDIANTE)
  activo     Boolean         @default(true)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  // Relaciones LMS
  cursos_impartidos lms_cursos[]
  matriculas        lms_matriculas[]
  entregas          lms_entregas[]
  progreso_recurso  lms_progreso_recurso[]
  progreso_modulo   lms_progreso_modulo[]
  notificaciones    lms_notificaciones[]
  certificados      lms_certificados[]
  sesiones          lms_sesiones_acceso[]
  metricas          lms_metricas_capacitacion?

  ultimo_acceso DateTime?
}

// ── ENUMS LMS ──

enum lms_estado_curso {
  BORRADOR
  PUBLICADO
  ARCHIVADO
}

enum lms_nivel_dificultad {
  PRINCIPIANTE
  INTERMEDIO
  AVANZADO
  EXPERTO
}

enum lms_tipo_recurso {
  TEXTO
  VIDEO
  PDF
  ENLACE
  TAREA
}

enum lms_tipo_evaluacion {
  QUIZ
  EXAMEN
  TAREA_ESCRITA
  TAREA_ARCHIVO
  PROYECTO_GRUPAL
}

enum lms_estado_entrega {
  BORRADOR
  ENTREGADA
  ENTREGADA_TARDE
  CALIFICADA
}

enum lms_tipo_pregunta {
  OPCION_MULTIPLE
  SELECCION_MULTIPLE
  VERDADERO_FALSO
  RESPUESTA_CORTA
  ENSAYO
}

enum lms_tipo_notificacion {
  EVALUACION_NUEVA
  DEADLINE_PROXIMO
  DEADLINE_URGENTE
  TAREA_CALIFICADA
  ANUNCIO_CURSO
  ANUNCIO_GLOBAL
  BIENVENIDA_CURSO
  BADGE_DESBLOQUEADO
  MODULO_COMPLETADO
}

enum lms_escala_calificacion {
  PORCENTAJE // 0-100
  PUNTOS // ej. 0-50
  LETRAS // A, B, C, D, F
}

enum lms_tipo_matricula {
  MANUAL // Inscrito por profesor/admin
  CODIGO_ACCESO // Estudiante usó un código unirse
  SISTEMA // Inscripción automática por reglas
}

// ── MODELOS CORE LMS ──

model lms_categorias {
  id          Int          @id @default(autoincrement())
  nombre      String
  descripcion String?
  color       String? // Hex color
  icono       String? // Lucide icon name
  activa      Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  deleted_at  DateTime?
  cursos      lms_cursos[]
}

model lms_cursos {
  guid              String               @id @default(uuid())
  titulo            String
  descripcion       String?
  descripcion_corta String?
  imagen_portada    String?
  categoria_id      Int?
  categoria         lms_categorias?      @relation(fields: [categoria_id], references: [id], onDelete: SetNull)
  nivel             lms_nivel_dificultad @default(PRINCIPIANTE)
  estado            lms_estado_curso     @default(BORRADOR)
  duracion_horas    Int?
  fecha_inicio      DateTime?
  fecha_fin         DateTime?
  codigo_acceso     String?              @unique
  max_estudiantes   Int?

  // Reglas de Negocio
  escala            lms_escala_calificacion @default(PORCENTAJE)
  nota_aprobacion   Decimal                 @default(60.0)
  orden_estricto    Boolean                 @default(true) // Fuerza linealidad (no saltar)
  emite_certificado Boolean                 @default(true)

  // Auditoría
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  // Relaciones
  profesor_guid  String
  profesor       usuarios             @relation(fields: [profesor_guid], references: [guid])
  modulos        lms_modulos[]
  matriculas     lms_matriculas[]
  evaluaciones   lms_evaluaciones[]
  anuncios       lms_anuncios[]
  calificaciones lms_calificaciones[]
  grupos         lms_grupos[]
  certificados   lms_certificados[]

  @@index([profesor_guid])
  @@index([categoria_id])
}

model lms_modulos {
  guid              String                @id @default(uuid())
  curso_guid        String
  curso             lms_cursos            @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  titulo            String
  descripcion       String?
  orden             Int                   @default(0)
  requiere_anterior Boolean               @default(false)
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt
  deleted_at        DateTime?
  lecciones         lms_lecciones[]
  progreso          lms_progreso_modulo[]

  @@index([curso_guid])
}

model lms_lecciones {
  guid        String         @id @default(uuid())
  modulo_guid String
  modulo      lms_modulos    @relation(fields: [modulo_guid], references: [guid], onDelete: Cascade)
  titulo      String
  descripcion String?
  orden       Int            @default(0)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  deleted_at  DateTime?
  recursos    lms_recursos[]

  @@index([modulo_guid])
}

model lms_recursos {
  guid           String                 @id @default(uuid())
  leccion_guid   String
  leccion        lms_lecciones          @relation(fields: [leccion_guid], references: [guid], onDelete: Cascade)
  titulo         String
  tipo           lms_tipo_recurso
  contenido_html String?
  url_archivo    String?
  orden          Int                    @default(0)
  obligatorio    Boolean                @default(true)
  tiempo_lectura Int? // Estimado en minutos
  created_at     DateTime               @default(now())
  updated_at     DateTime               @updatedAt
  deleted_at     DateTime?
  progreso       lms_progreso_recurso[]

  @@index([leccion_guid])
}

// ── EVALUACIONES Y PREGUNTAS ──

model lms_evaluaciones {
  guid                String              @id @default(uuid())
  curso_guid          String
  curso               lms_cursos          @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  titulo              String
  descripcion         String?
  tipo                lms_tipo_evaluacion
  Visible             Boolean             @default(false)
  peso_porcentual     Decimal             @default(0.0)
  nota_maxima         Decimal?            @default(100.0)
  fecha_apertura      DateTime
  fecha_cierre        DateTime
  intentos_permitidos Int                 @default(1)
  tiempo_limite_min   Int? // Para Quizzes/Exámenes
  mostrar_respuestas  Boolean             @default(false) // Al finalizar
  mezclar_preguntas   Boolean             @default(false)
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  deleted_at          DateTime?

  preguntas      lms_preguntas[]
  entregas       lms_entregas[]
  calificaciones lms_calificaciones[]
  excepciones    lms_evaluaciones_excepciones[]

  @@index([curso_guid])
}

model lms_evaluaciones_excepciones {
  id              Int              @id @default(autoincrement())
  evaluacion_guid String
  evaluacion      lms_evaluaciones @relation(fields: [evaluacion_guid], references: [guid], onDelete: Cascade)
  usuario_guid    String

  nueva_fecha_cierre  DateTime
  nuevo_tiempo_limite Int? // Permite darle más tiempo a una sola persona

  creado_por String? // Guid del Examinador/Admin
  created_at DateTime @default(now())

  @@unique([evaluacion_guid, usuario_guid])
}

model lms_preguntas {
  id              Int               @id @default(autoincrement())
  evaluacion_guid String
  evaluacion      lms_evaluaciones  @relation(fields: [evaluacion_guid], references: [guid], onDelete: Cascade)
  enunciado       String
  tipo            lms_tipo_pregunta
  puntos          Decimal           @default(1.0)
  orden           Int               @default(0)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  opciones   lms_opciones_pregunta[]
  respuestas lms_respuestas_quiz[]

  @@index([evaluacion_guid])
}

model lms_opciones_pregunta {
  id          Int           @id @default(autoincrement())
  pregunta_id Int
  pregunta    lms_preguntas @relation(fields: [pregunta_id], references: [id], onDelete: Cascade)
  texto       String
  es_correcta Boolean       @default(false)
  orden       Int           @default(0)

  respuestas lms_respuestas_quiz[]

  @@index([pregunta_id])
}

// ── ENTREGAS Y CALIFICACIONES ──

model lms_entregas {
  guid            String           @id @default(uuid())
  evaluacion_guid String
  evaluacion      lms_evaluaciones @relation(fields: [evaluacion_guid], references: [guid])
  usuario_guid    String
  usuario         usuarios         @relation(fields: [usuario_guid], references: [guid])
  grupo_guid      String?
  grupo           lms_grupos?      @relation(fields: [grupo_guid], references: [guid])

  estado          lms_estado_entrega @default(ENTREGADA)
  intento_numero  Int                @default(1)
  fecha_inicio    DateTime? // Para tracking de tiempo en examen
  fecha_entrega   DateTime?
  contenido_texto String?
  ip_address      String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  archivos     lms_entregas_archivos[]
  respuestas   lms_respuestas_quiz[]
  calificacion lms_calificaciones?

  @@index([evaluacion_guid])
  @@index([usuario_guid])
  @@index([grupo_guid])
}

model lms_entregas_archivos {
  id             Int          @id @default(autoincrement())
  entrega_guid   String
  entrega        lms_entregas @relation(fields: [entrega_guid], references: [guid], onDelete: Cascade)
  nombre_archivo String
  url_s3         String
  tipo_mime      String
  size_bytes     Int
  created_at     DateTime     @default(now())

  @@index([entrega_guid])
}

model lms_respuestas_quiz {
  id               Int                    @id @default(autoincrement())
  entrega_guid     String
  entrega          lms_entregas           @relation(fields: [entrega_guid], references: [guid], onDelete: Cascade)
  pregunta_id      Int
  pregunta         lms_preguntas          @relation(fields: [pregunta_id], references: [id])
  usuario_guid     String
  opcion_id        Int? // Si es opción múltiple
  opcion           lms_opciones_pregunta? @relation(fields: [opcion_id], references: [id])
  respuesta_texto  String? // Si es ensayo/corta
  puntos_obtenidos Decimal?
  es_correcta      Boolean?

  @@index([entrega_guid])
  @@index([pregunta_id])
}

model lms_calificaciones {
  id                 Int              @id @default(autoincrement())
  entrega_guid       String           @unique
  entrega            lms_entregas     @relation(fields: [entrega_guid], references: [guid], onDelete: Cascade)
  evaluacion_guid    String
  evaluacion         lms_evaluaciones @relation(fields: [evaluacion_guid], references: [guid])
  curso_guid         String
  curso              lms_cursos       @relation(fields: [curso_guid], references: [guid])
  nota               Decimal
  nota_maxima        Decimal
  comentarios        String?
  calificador_guid   String? // Puede ser null si es auto-calificado
  fecha_calificacion DateTime         @default(now())

  historial lms_calificaciones_historial[]

  @@index([evaluacion_guid])
  @@index([curso_guid])
}

model lms_calificaciones_historial {
  id                Int                @id @default(autoincrement())
  calificacion_id   Int
  calificacion      lms_calificaciones @relation(fields: [calificacion_id], references: [id], onDelete: Cascade)
  nota_anterior     Decimal
  nota_nueva        Decimal
  comentario_cambio String?
  modificado_por    String
  fecha_cambio      DateTime           @default(now())

  @@index([calificacion_id])
}

// ── PROGRESO Y MATRÍCULAS ──

model lms_progreso_recurso {
  id               Int          @id @default(autoincrement())
  usuario_guid     String
  usuario          usuarios     @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  recurso_guid     String
  recurso          lms_recursos @relation(fields: [recurso_guid], references: [guid], onDelete: Cascade)
  completado       Boolean      @default(true)
  fecha_completado DateTime     @default(now())
  tiempo_invertido Int? // Segundos

  @@unique([usuario_guid, recurso_guid])
}

model lms_progreso_modulo {
  id               Int         @id @default(autoincrement())
  usuario_guid     String
  usuario          usuarios    @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  modulo_guid      String
  modulo           lms_modulos @relation(fields: [modulo_guid], references: [guid], onDelete: Cascade)
  completado       Boolean     @default(false)
  fecha_completado DateTime?

  @@unique([usuario_guid, modulo_guid])
}

model lms_matriculas {
  id              Int                @id @default(autoincrement())
  usuario_guid    String
  usuario         usuarios           @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  curso_guid      String
  curso           lms_cursos         @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  tipo            lms_tipo_matricula @default(MANUAL)
  activa          Boolean            @default(true)
  fecha_matricula DateTime           @default(now())
  fecha_baja      DateTime?

  @@unique([usuario_guid, curso_guid])
}

// ── GRUPOS (Para proyectos colaborativos) ──

model lms_grupos {
  guid        String               @id @default(uuid())
  curso_guid  String
  curso       lms_cursos           @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  nombre      String
  descripcion String?
  created_at  DateTime             @default(now())
  entregas    lms_entregas[]
  miembros    lms_grupo_miembros[]

  @@index([curso_guid])
}

model lms_grupo_miembros {
  id           Int        @id @default(autoincrement())
  grupo_guid   String
  grupo        lms_grupos @relation(fields: [grupo_guid], references: [guid], onDelete: Cascade)
  usuario_guid String
  es_lider     Boolean    @default(false)
  agregado_en  DateTime   @default(now())

  @@unique([grupo_guid, usuario_guid])
}

// ── COMUNICACIÓN Y GAMIFICACIÓN ──

model lms_notificaciones {
  id           Int                   @id @default(autoincrement())
  usuario_guid String
  usuario      usuarios              @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  tipo         lms_tipo_notificacion
  titulo       String
  mensaje      String
  leida        Boolean               @default(false)
  url_accion   String? // Link para ver detalle (ej. /lms/cursos/123)
  ref_tipo     String? // 'curso', 'evaluacion', 'entrega'
  ref_guid     String?
  created_at   DateTime              @default(now())

  @@index([usuario_guid])
}

model lms_anuncios {
  id            Int         @id @default(autoincrement())
  curso_guid    String? // Null = anuncio global
  curso         lms_cursos? @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  autor_guid    String
  titulo        String
  contenido     String
  fijado        Boolean     @default(false)
  enviar_correo Boolean     @default(false)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  @@index([curso_guid])
}

// ── MÉTRICAS Y AUDITORÍA PESV (REEMPLAZO DE GAMIFICACIÓN) ──

model lms_sesiones_acceso {
  id            Int       @id @default(autoincrement())
  usuario_guid  String
  usuario       usuarios  @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  fecha_entrada DateTime  @default(now())
  fecha_salida  DateTime?
  ip_address    String?
  dispositivo   String?

  @@index([usuario_guid])
}

model lms_metricas_capacitacion {
  id                     Int      @id @default(autoincrement())
  usuario_guid           String   @unique
  usuario                usuarios @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  dias_consecutivos      Int      @default(0)
  total_horas_invertidas Decimal  @default(0.0) // Tiempo total auditable
  cursos_completados     Int      @default(0)
  promedio_global        Decimal  @default(0.0)

  updated_at DateTime @updatedAt
}

model lms_certificados {
  id                 Int        @id @default(autoincrement())
  uuid_verificacion  String     @unique @default(uuid())
  usuario_guid       String
  usuario            usuarios   @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  curso_guid         String
  curso              lms_cursos @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  fecha_emision      DateTime   @default(now())
  horas_certificadas Int // Se graba para auditoría en caso de que el curso cambie luego
  url_pdf            String?

  @@unique([usuario_guid, curso_guid])
}

// ── CONFIGURACIÓN Y AUDITORÍA ──

model lms_configuracion {
  id                Int      @id @default(autoincrement()) // Solo habrá fila id=1
  nombre_plataforma String   @default("Campus Virtual")
  logo_url          String?
  color_primario    String   @default("#4f46e5")
  color_secundario  String   @default("#10b981")
  idioma            String   @default("es")
  zona_horaria      String   @default("America/Bogota")
  max_archivo_mb    Int      @default(10)
  email_remitente   String?
  email_nombre      String?
  bienvenida_html   String?
  updated_at        DateTime @updatedAt
}

model lms_auditoria {
  id               Int      @id @default(autoincrement())
  usuario_guid     String?
  accion           String // ej. "crear_curso"
  entidad          String // ej. "lms_cursos"
  entidad_id       String?
  descripcion      String?
  datos_anteriores Json?
  datos_nuevos     Json?
  ip_address       String?
  user_agent       String?
  created_at       DateTime @default(now())

  @@index([usuario_guid])
  @@index([accion])
  @@index([entidad, entidad_id])
}
