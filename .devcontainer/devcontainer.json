
{
	"name": "PESV Fullstack Dev Container",
	// Apunta al archivo de Docker Compose específico para el entorno de desarrollo.
	"dockerComposeFile": [
		"./docker-compose.dev.yaml"
	],
	// El servicio al que VS Code se "conectará".
	"service": "dev",
	// La carpeta que se abrir en VS Code dentro del contenedor.
	"workspaceFolder": "/workspace",
	"features": {
		"ghcr.io/devcontainers/features/common-utils": {
			"installZsh": true,
			"installOhMyZsh": true,
			"installOhMyZshConfig": true,
			"configureZshAsDefaultShell": true
		},
    "ghcr.io/devcontainers/features/git:1": {},
		"ghcr.io/devcontainers-extra/features/zsh-plugins:0": {
			"plugins": "zsh-autosuggestions zsh-syntax-highlighting",
			"omzPlugins": "https://github.com/zsh-users/zsh-autosuggestions.git https://github.com/zsh-users/zsh-syntax-highlighting.git"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {}
	},
	// Personalizaciones para VS Code dentro del contenedor.
	"customizations": {
		"vscode": {
			"settings": {
				"editor.tabSize": 2,
				"editor.fontFamily": "FiraCode Nerd Font, Fira Code, monospace", // Fuentes para el editor. Se usará la primera que encuentre instalada en tu máquina local.
				"editor.fontLigatures": true,
				"terminal.integrated.fontFamily": "FiraCode Nerd Font Mono, monospace", // Usar la misma fuente para consistencia
				"terminal.integrated.fontLigatures.enabled": true
			},
			// Extensiones que se instalarán automáticamente en el Dev Container.
			"extensions": [
				"dbaeumer.vscode-eslint",
				"prisma.prisma",
				"ms-vscode.vscode-typescript-next",
				"mikestead.dotenv",
				"pkief.material-icon-theme",
				"wayou.vscode-todo-highlight",
				"cweijan.dbclient-jdbc",
				"editorconfig.editorconfig",
				"google.geminicodeassist",
				"orta.vscode-jest",
				"christian-kohler.npm-intellisense",
				"esbenp.prettier-vscode",
				"abians.prisma-generate-uml",
				"gruntfuggly.todo-tree",
				"redhat.vscode-yaml",
				"eamodio.gitlens",
				"firefox-devtools.vscode-firefox-debug",
				"aaravb.chrome-extension-developer-tools",
				"cweijan.vscode-mysql-client2",
				"GitHub.copilot-chat",
				"ms-azuretools.vscode-containers"
			]
		}
	},
	"postCreateCommand": "sudo chmod +x .devcontainer/scripts/post-create.sh && .devcontainer/scripts/post-create.sh",
	"remoteUser": "node",
	"updateRemoteUserUID": true,
	"mounts": [
    "source=profile,target=/home/node,type=volume",
		"source=vscode-server,target=/home/node/.vscode-server,type=volume"
	],
	// Puertos para desarrollo
	"portsAttributes": {
		"3100": {
			"label": "API Server",
			"onAutoForward": "openBrowser"
		},
		"3000": {
			"label": "Frontend",
			"onAutoForward": "openBrowser"
		},
		"9229": {
			"label": "API Debugger"
		},
		"9230": {
			"label": "Client Debugger"
		},
		"3306": {
			"label": "MySQL Database"
		}
	},
	"shutdownAction": "stopCompose"
}
