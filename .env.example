# ═══════════════════════════════════════════════════════════════
# LMS — Development Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
# NEVER commit the actual .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="mysql://lms_user:lms_password@localhost:3307/lms_db"

# ── JWT Authentication ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# ── Server ────────────────────────────────────────────────────
APP_PORT=3200

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3100"

# ── Frontend API URL ──────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3200/api"

# ── Application URL (used in emails and certificates) ─────────
APP_URL="http://localhost:3100"

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_FROM_NAME="Proyecto LMS"

# ── Cloudflare R2 Storage (leave empty to use local fallback) ──
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="lms-uploads"
# ⚠️ DO NOT set R2_PUBLIC_URL — it exposes private files (entregas, firmas,
#    certificados) without authentication. All files are proxied through the
#    API with JWT validation (Strategy 2).
