generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ── SISTEMA DE AUTENTICACIÓN INDEPENDIENTE ──

enum lms_rol_usuario {
  ADMINISTRADOR
  PROFESOR
  ESTUDIANTE
}

model usuarios {
  guid              String          @id @default(uuid())
  email             String          @unique
  contrasena        String?         // Nullable for accounts created by Admin without password
  nombre            String
  apellido          String
  rol               lms_rol_usuario @default(ESTUDIANTE)
  activo            Boolean         @default(true)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  // Relaciones LMS
  cursos_impartidos lms_cursos[]
  matriculas        lms_matriculas[]
  entregas          lms_entregas[]
  progreso_recurso  lms_progreso_recurso[]
  notificaciones    lms_notificaciones[]
  metricas          lms_metricas_capacitacion?
  certificados      lms_certificados[]
  sesiones_activas  lms_sesion_activa[]
  mensajes_enviados   lms_mensajes[] @relation("mensajes_enviados")
  mensajes_recibidos  lms_mensajes[] @relation("mensajes_recibidos")

  ultimo_acceso     DateTime?
  usa_clave_defecto Boolean         @default(true)

  // Firma del examinador/instructor (para certificados)
  firma_url         String?
  firma_nombre      String?
  firma_cargo       String?
}

// ── ENUMS LMS ──

enum lms_estado_curso {
  BORRADOR
  PUBLICADO
  ARCHIVADO
}

enum lms_nivel_dificultad {
  PRINCIPIANTE
  INTERMEDIO
  AVANZADO
  EXPERTO
}

enum lms_tipo_recurso {
  TEXTO
  VIDEO
  PDF
  ENLACE
  TAREA
}

enum lms_estado_entrega {
  BORRADOR
  ENTREGADA
  ENTREGADA_TARDE
  CALIFICADA
  EN_REVISION
}

enum lms_tipo_notificacion {
  EVALUACION_NUEVA
  DEADLINE_PROXIMO
  DEADLINE_URGENTE
  TAREA_CALIFICADA
  ANUNCIO_CURSO
  ANUNCIO_GLOBAL
  BIENVENIDA_CURSO
  BADGE_DESBLOQUEADO
  MODULO_COMPLETADO
  MODULO_REINICIADO
  REVISION_ENTREGA
  ENTREGA_RECHAZADA
  CURSO_REACTIVADO
  RECORDATORIO_INACTIVIDAD
  MENSAJE_NUEVO
}

enum lms_escala_calificacion {
  NUMERICA   // 0.0-5.0 (default)
  PORCENTAJE // 0-100
  PUNTOS     // ej. 0-50
  LETRAS     // A, B, C, D, F
}

enum lms_tipo_matricula {
  MANUAL // Inscrito por profesor/admin
  CODIGO_ACCESO // Estudiante usó un código unirse
  SISTEMA // Inscripción automática por reglas
}

enum lms_estado_solicitud {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

// ── SISTEMA DE SOLICITUDES DE ACCESO ──
model lms_solicitudes_acceso {
  id         Int                  @id @default(autoincrement())
  email      String               @unique
  nombre     String
  apellido   String
  rol_pedido lms_rol_usuario
  estado     lms_estado_solicitud @default(PENDIENTE)
  created_at DateTime             @default(now())
}

// ── MODELOS CORE LMS ──

model lms_cursos {
  guid              String             @id @default(uuid())
  titulo            String
  descripcion       String?            @db.Text
  descripcion_corta String?
  imagen_portada    String?
  nivel             lms_nivel_dificultad @default(PRINCIPIANTE)
  estado            lms_estado_curso   @default(BORRADOR)
  duracion_horas    Int?
  fecha_inicio      DateTime?
  fecha_fin         DateTime?
  codigo_acceso     String?            @unique
  max_estudiantes   Int?

  // Reglas de Negocio
  escala            lms_escala_calificacion @default(NUMERICA)
  nota_aprobacion   Decimal            @default(3.0) // Mínima para aprobar en escala 0.0-5.0
  orden_estricto    Boolean            @default(true) // Fuerza linealidad (no saltar)
  emite_certificado Boolean            @default(true)

  // Auditoría
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  deleted_at        DateTime?

  // Relaciones
  profesor_guid     String
  profesor          usuarios           @relation(fields: [profesor_guid], references: [guid], onDelete: Cascade)
  modulos           lms_modulos[]
  matriculas        lms_matriculas[]
  certificados      lms_certificados[]
  sesiones_activas  lms_sesion_activa[]

  @@index([profesor_guid])
}

model lms_modulos {
  guid              String             @id @default(uuid())
  curso_guid        String
  curso             lms_cursos         @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  titulo            String
  descripcion       String?
  orden             Int                @default(0)
  requiere_anterior Boolean            @default(false)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  deleted_at        DateTime?
  lecciones         lms_lecciones[]

  @@index([curso_guid])
}

model lms_lecciones {
  guid        String         @id @default(uuid())
  modulo_guid String
  modulo      lms_modulos    @relation(fields: [modulo_guid], references: [guid], onDelete: Cascade)
  titulo      String
  descripcion String?
  orden       Int            @default(0)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  deleted_at  DateTime?
  recursos    lms_recursos[]

  @@index([modulo_guid])
}

model lms_recursos {
  guid                  String                @id @default(uuid())
  leccion_guid          String
  leccion               lms_lecciones         @relation(fields: [leccion_guid], references: [guid], onDelete: Cascade)
  titulo                String
  tipo                  lms_tipo_recurso
  contenido_html        String?            @db.Text
  url_archivo           String?
  url_referencia        String?               // URL externa opcional para recursos adicionales
  archivo_adjunto       String?               @db.LongText // Base64 del archivo adjunto (PDF, Word, PPT, etc.)
  archivo_adjunto_nombre String?              // Nombre original del archivo adjunto
  archivo_max_size_mb   Int?                  // Límite de peso de archivo en MB (admin y estudiante)
  quiz_config           String?               @db.Text // JSON: { intentos_permitidos, tiempo_minutos, preguntas: [...] }
  orden                 Int                   @default(0)
  obligatorio           Boolean               @default(true)
  tiempo_lectura        Int?                  // Estimado en minutos
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  deleted_at            DateTime?
  progreso              lms_progreso_recurso[]
  entregas              lms_entregas[]

  @@index([leccion_guid])
}

// ── ENTREGAS ──

model lms_entregas {
  guid            String               @id @default(uuid())
  usuario_guid    String
  usuario         usuarios             @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  tarea_guid      String?              // GUID del recurso tipo TAREA (lms_recursos)
  tarea           lms_recursos?        @relation(fields: [tarea_guid], references: [guid], onDelete: SetNull)
  url_archivo_adjunto String?          // Nombre del archivo subido en servidor (uploads/)
  respuesta_texto String?              // Nombre original del archivo entregado

  estado          lms_estado_entrega   @default(ENTREGADA)
  intento_numero  Int                  @default(1)
  fecha_inicio    DateTime?            // Para tracking de tiempo en examen
  fecha_entrega   DateTime?
  contenido_texto String?              @db.Text
  calificacion    Decimal?             // Nota numérica (ej. 4.5) — reemplaza parseo de contenido_texto
  comentario_calificacion String?      @db.Text // Comentario del examinador al calificar
  ip_address      String?
  archivo_purgado Boolean              @default(false) // true = archivo eliminado tras obtener certificado

  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt

  @@index([usuario_guid])
  @@index([tarea_guid])
  @@index([tarea_guid, usuario_guid])
  @@index([estado])
}

// ── PROGRESO Y MATRÍCULAS ──

model lms_progreso_recurso {
  id              Int          @id @default(autoincrement())
  usuario_guid    String
  usuario         usuarios     @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  recurso_guid    String
  recurso         lms_recursos @relation(fields: [recurso_guid], references: [guid], onDelete: Cascade)
  completado      Boolean      @default(true)
  fecha_completado DateTime    @default(now())
  tiempo_invertido Int?        // Segundos

  @@unique([usuario_guid, recurso_guid])
}

model lms_matriculas {
  id              Int                @id @default(autoincrement())
  usuario_guid    String
  usuario         usuarios           @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  curso_guid      String
  curso           lms_cursos         @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  tipo            lms_tipo_matricula @default(MANUAL)
  activa          Boolean            @default(true)
  fecha_matricula DateTime           @default(now())
  fecha_baja      DateTime?

  @@unique([usuario_guid, curso_guid])
}

// ── COMUNICACIÓN ──

model lms_notificaciones {
  id           Int                   @id @default(autoincrement())
  usuario_guid String
  usuario      usuarios              @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  tipo         lms_tipo_notificacion
  titulo       String
  mensaje      String
  leida        Boolean               @default(false)
  url_accion   String?               // Link para ver detalle (ej. /lms/cursos/123)
  ref_tipo     String?               // 'curso', 'evaluacion', 'entrega'
  ref_guid     String?
  created_at   DateTime              @default(now())

  @@index([usuario_guid])
}

// ── MENSAJERÍA ──

model lms_mensajes {
  id              Int      @id @default(autoincrement())
  remitente_guid  String
  remitente       usuarios @relation("mensajes_enviados", fields: [remitente_guid], references: [guid], onDelete: Cascade)
  destinatario_guid String
  destinatario    usuarios @relation("mensajes_recibidos", fields: [destinatario_guid], references: [guid], onDelete: Cascade)
  asunto          String
  contenido       String               @db.Text
  leido           Boolean  @default(false)
  ref_tipo        String?  // 'quiz_retry', 'entrega_revision', 'general'
  ref_guid        String?  // GUID del recurso/entrega relacionado
  created_at      DateTime @default(now())

  @@index([remitente_guid])
  @@index([destinatario_guid])
}

// ── RECUPERACIÓN DE CONTRASEÑA ──

model lms_password_resets {
  id         Int      @id @default(autoincrement())
  email      String
  token      String   @unique
  usado      Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
}

// ── MÉTRICAS PESV ──

model lms_metricas_capacitacion {
  id                     Int      @id @default(autoincrement())
  usuario_guid           String   @unique
  usuario                usuarios @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  dias_consecutivos      Int      @default(0)
  total_horas_invertidas Decimal  @default(0.0) // Tiempo total auditable
  cursos_completados     Int      @default(0)
  promedio_global        Decimal  @default(0.0)

  updated_at             DateTime @updatedAt
}

// ── CONFIGURACIÓN ──

model lms_configuracion {
  id                 Int      @id @default(autoincrement()) // Solo habrá fila id=1
  nombre_plataforma  String   @default("Campus Virtual")
  logo_url           String?
  favicon_url        String?
  color_primario     String   @default("#4f46e5")
  color_secundario   String   @default("#10b981")
  fuente             String   @default("Inter")
  border_radius      Int      @default(12)     // px
  login_fondo_url    String?
  mensaje_bienvenida String   @default("Bienvenido PESV")
  idioma             String   @default("es")
  zona_horaria       String   @default("America/Bogota")
  max_archivo_mb     Int      @default(10)
  contrasena_defecto String   @default("pesvauth2026") // Contraseña por defecto para nuevos usuarios
  email_remitente    String?
  email_nombre       String?
  bienvenida_html    String?            @db.Text

  // Certificados config
  cert_titulo_personalizado String?
  cert_subtitulo            String?
  cert_texto_legal          String?
  cert_mostrar_modulos      Boolean  @default(true)
  cert_mostrar_recursos     Boolean  @default(true)
  cert_mostrar_nota         Boolean  @default(true)
  cert_mostrar_firma        Boolean  @default(true)
  cert_mostrar_fecha_ingreso Boolean @default(false)

  // Landing Page - Hero
  landing_hero_titulo1   String   @default("Transporte Seguro,")
  landing_hero_titulo2   String   @default("Personal Capacitado")
  landing_hero_subtitulo String   @default("Plataforma integral para la gestión del Plan Estratégico de Seguridad Vial. Capacitación, evaluación y certificación de conductores con tecnología de vanguardia.")

  // Landing Page - Contacto
  landing_telefono       String   @default("+57 300 123 4567")
  landing_telefono_sub   String   @default("Lun-Vie 8am-6pm")
  landing_email          String   @default("contacto@pesveducation.com")
  landing_email_sub      String   @default("Respuesta en 24h")
  landing_oficina        String   @default("Bogotá, Colombia")
  landing_oficina_sub    String   @default("Cra 7 #45-21, Oficina 302")

  // Landing Page - Footer
  landing_footer_texto   String   @default("Plataforma líder en capacitación y certificación de seguridad vial para empresas de transporte de carga.")

  // Página Legal
  legal_terminos         String?  @db.Text
  legal_privacidad       String?  @db.Text
  legal_datos            String?  @db.Text

  updated_at         DateTime @updatedAt
}

// ── CERTIFICADOS ──

model lms_certificados {
  id                  Int      @id @default(autoincrement())
  guid                String   @unique @default(uuid())
  usuario_guid        String
  usuario             usuarios @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  curso_guid          String
  curso               lms_cursos @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  codigo_verificacion String   @unique
  archivo_pdf         String
  fecha_inicio        DateTime
  fecha_completado    DateTime @default(now())
  tiempo_total_horas  Decimal  @default(0)
  tiempo_activo_seg   Int      @default(0)
  nota_promedio       Decimal?
  created_at          DateTime @default(now())

  @@unique([usuario_guid, curso_guid])
  @@index([usuario_guid])
  @@index([curso_guid])
}

// ── SESIONES ACTIVAS (Heartbeat tracking) ──

model lms_sesion_activa {
  id            Int       @id @default(autoincrement())
  usuario_guid  String
  usuario       usuarios  @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  curso_guid    String
  curso         lms_cursos @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  inicio_sesion DateTime  @default(now())
  fin_sesion    DateTime?
  duracion_seg  Int       @default(0)

  @@index([usuario_guid, curso_guid])
}


// ── CONTACTOS DE CHAT (Aprobación mutua) ──

enum lms_estado_contacto {
  PENDIENTE
  ACEPTADO
  RECHAZADO
}

model lms_contacto_chat {
  id                Int                  @id @default(autoincrement())
  solicitante_guid  String
  receptor_guid     String
  curso_guid        String
  estado            lms_estado_contacto  @default(PENDIENTE)
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt

  @@unique([solicitante_guid, receptor_guid, curso_guid])
  @@index([receptor_guid])
  @@index([solicitante_guid])
}

// ── TOKEN REVOCATIONS (for JWT blacklist persistence) ──

model lms_token_revocations {
  id            Int      @id @default(autoincrement())
  usuario_guid  String
  revoked_at    DateTime @default(now())
  expires_at    DateTime // Auto-cleanup: delete after JWT max lifetime (25h)

  @@index([usuario_guid])
  @@index([expires_at])
}

// ── PLANTILLAS DE CORREO ──

model lms_eventos_correo {
  id               Int      @id @default(autoincrement())
  identificador    String   @unique // Ej: 'RECUPERAR_PASSWORD', 'NUEVA_ENTREGA'
  nombre_legible   String   
  descripcion      String
  variables        String   @db.Text // JSON array de variables permitidas ej: ["nombre", "token", "curso"]
  plantillas       lms_plantillas_correo[]
}

model lms_plantillas_correo {
  id               Int      @id @default(autoincrement())
  evento_id        Int
  evento           lms_eventos_correo @relation(fields: [evento_id], references: [id], onDelete: Cascade)
  nombre_interno   String   // Para que el admin lo identifique
  asunto           String
  cuerpo_html      String   @db.Text
  activo           Boolean  @default(true)
  es_sistema       Boolean  @default(false) // Las de sistema no se pueden borrar
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}
