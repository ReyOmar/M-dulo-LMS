generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── SISTEMA DE AUTENTICACIÓN INDEPENDIENTE ──

enum lms_rol_usuario {
  ADMINISTRADOR
  PROFESOR
  ESTUDIANTE
}

model usuarios {
  guid              String          @id @default(uuid())
  email             String          @unique
  contrasena        String?         // Nullable for accounts created by Admin without password
  nombre            String
  apellido          String
  rol               lms_rol_usuario @default(ESTUDIANTE)
  activo            Boolean         @default(true)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  // Relaciones LMS
  cursos_impartidos lms_cursos[]
  matriculas        lms_matriculas[]
  entregas          lms_entregas[]
  progreso_recurso  lms_progreso_recurso[]
  notificaciones    lms_notificaciones[]
  metricas          lms_metricas_capacitacion?

  ultimo_acceso     DateTime?
}

// ── ENUMS LMS ──

enum lms_estado_curso {
  BORRADOR
  PUBLICADO
  ARCHIVADO
}

enum lms_nivel_dificultad {
  PRINCIPIANTE
  INTERMEDIO
  AVANZADO
  EXPERTO
}

enum lms_tipo_recurso {
  TEXTO
  VIDEO
  PDF
  ENLACE
  TAREA
}

enum lms_estado_entrega {
  BORRADOR
  ENTREGADA
  ENTREGADA_TARDE
  CALIFICADA
}

enum lms_tipo_notificacion {
  EVALUACION_NUEVA
  DEADLINE_PROXIMO
  DEADLINE_URGENTE
  TAREA_CALIFICADA
  ANUNCIO_CURSO
  ANUNCIO_GLOBAL
  BIENVENIDA_CURSO
  BADGE_DESBLOQUEADO
  MODULO_COMPLETADO
}

enum lms_escala_calificacion {
  PORCENTAJE // 0-100
  PUNTOS // ej. 0-50
  LETRAS // A, B, C, D, F
}

enum lms_tipo_matricula {
  MANUAL // Inscrito por profesor/admin
  CODIGO_ACCESO // Estudiante usó un código unirse
  SISTEMA // Inscripción automática por reglas
}

enum lms_estado_solicitud {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

// ── SISTEMA DE SOLICITUDES DE ACCESO ──
model lms_solicitudes_acceso {
  id         Int                  @id @default(autoincrement())
  email      String               @unique
  nombre     String
  apellido   String
  rol_pedido lms_rol_usuario
  estado     lms_estado_solicitud @default(PENDIENTE)
  created_at DateTime             @default(now())
}

// ── MODELOS CORE LMS ──

model lms_cursos {
  guid              String             @id @default(uuid())
  titulo            String
  descripcion       String?
  descripcion_corta String?
  imagen_portada    String?
  nivel             lms_nivel_dificultad @default(PRINCIPIANTE)
  estado            lms_estado_curso   @default(BORRADOR)
  duracion_horas    Int?
  fecha_inicio      DateTime?
  fecha_fin         DateTime?
  codigo_acceso     String?            @unique
  max_estudiantes   Int?

  // Reglas de Negocio
  escala            lms_escala_calificacion @default(PORCENTAJE)
  nota_aprobacion   Decimal            @default(60.0)
  orden_estricto    Boolean            @default(true) // Fuerza linealidad (no saltar)
  emite_certificado Boolean            @default(true)

  // Auditoría
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  deleted_at        DateTime?

  // Relaciones
  profesor_guid     String
  profesor          usuarios           @relation(fields: [profesor_guid], references: [guid])
  modulos           lms_modulos[]
  matriculas        lms_matriculas[]

  @@index([profesor_guid])
}

model lms_modulos {
  guid              String             @id @default(uuid())
  curso_guid        String
  curso             lms_cursos         @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  titulo            String
  descripcion       String?
  orden             Int                @default(0)
  requiere_anterior Boolean            @default(false)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  deleted_at        DateTime?
  lecciones         lms_lecciones[]

  @@index([curso_guid])
}

model lms_lecciones {
  guid        String         @id @default(uuid())
  modulo_guid String
  modulo      lms_modulos    @relation(fields: [modulo_guid], references: [guid], onDelete: Cascade)
  titulo      String
  descripcion String?
  orden       Int            @default(0)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  deleted_at  DateTime?
  recursos    lms_recursos[]

  @@index([modulo_guid])
}

model lms_recursos {
  guid                  String                @id @default(uuid())
  leccion_guid          String
  leccion               lms_lecciones         @relation(fields: [leccion_guid], references: [guid], onDelete: Cascade)
  titulo                String
  tipo                  lms_tipo_recurso
  contenido_html        String?
  url_archivo           String?
  url_referencia        String?               // URL externa opcional para recursos adicionales
  archivo_adjunto       String?               // Base64 del archivo adjunto (PDF, Word, PPT, etc.)
  archivo_adjunto_nombre String?              // Nombre original del archivo adjunto
  archivo_max_size_mb   Int?                  // Límite de peso de archivo en MB (admin y estudiante)
  quiz_config           String?               // JSON: { intentos_permitidos, tiempo_minutos, preguntas: [...] }
  orden                 Int                   @default(0)
  obligatorio           Boolean               @default(true)
  tiempo_lectura        Int?                  // Estimado en minutos
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  deleted_at            DateTime?
  progreso              lms_progreso_recurso[]

  @@index([leccion_guid])
}

// ── ENTREGAS ──

model lms_entregas {
  guid            String               @id @default(uuid())
  usuario_guid    String
  usuario         usuarios             @relation(fields: [usuario_guid], references: [guid])
  tarea_guid      String?              // GUID del recurso tipo TAREA (lms_recursos)
  url_archivo_adjunto String?          // Nombre del archivo subido en servidor (uploads/)
  respuesta_texto String?              // Nombre original del archivo entregado

  estado          lms_estado_entrega   @default(ENTREGADA)
  intento_numero  Int                  @default(1)
  fecha_inicio    DateTime?            // Para tracking de tiempo en examen
  fecha_entrega   DateTime?
  contenido_texto String?
  ip_address      String?

  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt

  @@index([usuario_guid])
}

// ── PROGRESO Y MATRÍCULAS ──

model lms_progreso_recurso {
  id              Int          @id @default(autoincrement())
  usuario_guid    String
  usuario         usuarios     @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  recurso_guid    String
  recurso         lms_recursos @relation(fields: [recurso_guid], references: [guid], onDelete: Cascade)
  completado      Boolean      @default(true)
  fecha_completado DateTime    @default(now())
  tiempo_invertido Int?        // Segundos

  @@unique([usuario_guid, recurso_guid])
}

model lms_matriculas {
  id              Int                @id @default(autoincrement())
  usuario_guid    String
  usuario         usuarios           @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  curso_guid      String
  curso           lms_cursos         @relation(fields: [curso_guid], references: [guid], onDelete: Cascade)
  tipo            lms_tipo_matricula @default(MANUAL)
  activa          Boolean            @default(true)
  fecha_matricula DateTime           @default(now())
  fecha_baja      DateTime?

  @@unique([usuario_guid, curso_guid])
}

// ── COMUNICACIÓN ──

model lms_notificaciones {
  id           Int                   @id @default(autoincrement())
  usuario_guid String
  usuario      usuarios              @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  tipo         lms_tipo_notificacion
  titulo       String
  mensaje      String
  leida        Boolean               @default(false)
  url_accion   String?               // Link para ver detalle (ej. /lms/cursos/123)
  ref_tipo     String?               // 'curso', 'evaluacion', 'entrega'
  ref_guid     String?
  created_at   DateTime              @default(now())

  @@index([usuario_guid])
}

// ── MÉTRICAS PESV ──

model lms_metricas_capacitacion {
  id                     Int      @id @default(autoincrement())
  usuario_guid           String   @unique
  usuario                usuarios @relation(fields: [usuario_guid], references: [guid], onDelete: Cascade)
  dias_consecutivos      Int      @default(0)
  total_horas_invertidas Decimal  @default(0.0) // Tiempo total auditable
  cursos_completados     Int      @default(0)
  promedio_global        Decimal  @default(0.0)

  updated_at             DateTime @updatedAt
}

// ── CONFIGURACIÓN ──

model lms_configuracion {
  id                 Int      @id @default(autoincrement()) // Solo habrá fila id=1
  nombre_plataforma  String   @default("Campus Virtual")
  logo_url           String?
  favicon_url        String?
  color_primario     String   @default("#4f46e5")
  color_secundario   String   @default("#10b981")
  fuente             String   @default("Inter")
  border_radius      Int      @default(12)     // px
  login_fondo_url    String?
  mensaje_bienvenida String   @default("Bienvenido PESV")
  idioma             String   @default("es")
  zona_horaria       String   @default("America/Bogota")
  max_archivo_mb     Int      @default(10)
  contrasena_defecto String   @default("pesvauth2026") // Contraseña por defecto para nuevos usuarios
  email_remitente    String?
  email_nombre       String?
  bienvenida_html    String?
  updated_at         DateTime @updatedAt
}
